{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jukebox",
  "compatibility_date": "2025-12-10",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./build/",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "jukebox.teachstack.org",
      "custom_domain": true
    }
  ]
}